layout {
    gaps 10
    center-focused-column "never"
    background-color "transparent"
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
    default-column-width {
        proportion 0.5
    }
    focus-ring {
        width 1
    }
    border {
        width 1
    }
    shadow {
        off
    }
    struts {

    }
}
